generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProblemDifficulty {
  EASY
  NORMAL
  HARD
}

enum ProblemType {
  PRACTICE
  CONTEST
}

enum Role {
  USER
  ADMIN
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Problem {
  id             String          @id @default(cuid())
  name           String
  url            String          @unique
  solves         Solve[]
  moduleProblems ModuleProblem[]

  @@map("Problems")
}

// Tracks consist of modules
model Track {
  id   String @id @default(cuid())
  name String

  levels    TrackLevel[]
  userTrack UserTrack[]
}

// Tracks have levels
model TrackLevel {
  id      String @id @default(cuid())
  trackId String
  code    String // A, B, C1... and such
  order   Int

  track        Track         @relation(fields: [trackId], references: [id], onDelete: Cascade)
  levelModules LevelModule[]

  @@unique([trackId, code])
}

// Modules belong to levels (could be in multiple tracks)
model LevelModule {
  id           String @id @default(cuid())
  trackLevelId String
  moduleId     String
  order        Int

  trackLevel TrackLevel @relation(fields: [trackLevelId], references: [id], onDelete: Cascade)
  module     Module     @relation(fields: [moduleId], references: [id])

  @@unique([trackLevelId, moduleId])
}

model Module {
  id   String @id @default(cuid())
  name String

  moduleProblems ModuleProblem[]
  levelModules   LevelModule[]
}

// Problems belong to modules
model ModuleProblem {
  id          String            @id @default(cuid())
  moduleId    String
  problemId   String
  problemType ProblemType
  difficulty  ProblemDifficulty

  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Restrict)

  @@unique([moduleId, problemId])
}

// Store all problems solved by user
model Solve {
  id        String @id @default(cuid())
  userId    String
  problemId String

  submitCount Int

  readTimeMinutes  Int
  thinkTimeMinutes Int
  codeTimeMinutes  Int
  debugTimeMinutes Int

  notes String?
  mood  String?

  onYourOwn Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Restrict)

  @@unique([userId, problemId])
}

model UserTrack {
  id      String @id @default(cuid())
  userId  String
  trackId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id])

  @@unique([userId, trackId])
}

// User + Auth tables
model User {
  id    String  @id @default(cuid())
  email String? @unique
  name  String?
  role  Role    @default(USER)

  solves     Solve[]
  userTracks UserTrack[]
  account    Account[]
  sessions   Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String?
  refresh_token     String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
